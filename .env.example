# OnchainMind environment configuration
# Copy this file to .env and adjust values as needed.
# All variables are optional; defaults are applied when unset.

# Pharos RPC endpoint
ONCHAINMIND_PHAROS_RPC_URL=https://testnet.pharosnetwork.xyz

# Log level: debug | info | warn | error
ONCHAINMIND_LOG_LEVEL=info

# MCP transport: stdio | sse
ONCHAINMIND_MCP_TRANSPORT=stdio

# SSE server port (used when transport is "sse")
ONCHAINMIND_SSE_PORT=3002

# Cache time-to-live in milliseconds
ONCHAINMIND_CACHE_TTL_MS=30000

# Retry configuration
ONCHAINMIND_RETRY_MAX_ATTEMPTS=3
ONCHAINMIND_RETRY_BASE_DELAY_MS=1000

# Bearer token required to authenticate SSE transport requests.
# REQUIRED when ONCHAINMIND_MCP_TRANSPORT=sse: the SSE endpoints expose every
# registered skill over HTTP and fail closed (HTTP 503) when this is unset.
# Not used by the stdio transport.
ONCHAINMIND_AUTH_TOKEN=
